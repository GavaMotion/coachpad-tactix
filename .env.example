# ── Supabase (required) ──────────────────────────────────────────
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Supabase service role key (admin scripts only — NEVER ship to the browser) ──
# Used by scripts/admin-users.mjs to list users with filters.
# Get it from Supabase → Settings → API → "service_role" key.
# Bypasses Row Level Security, so guard it carefully and never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic API key (server-side only — NOT prefixed with VITE_) ─
# This key is used by the Supabase Edge Function, not the browser.
# Do NOT add it here. Instead:
#
#   1. For local dev, create  supabase/.env  (already gitignored) and add:
#        ANTHROPIC_API_KEY=sk-ant-...
#      Then run: supabase functions serve practice-plan --env-file supabase/.env
#
#   2. For production, run:
#        supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#        supabase functions deploy practice-plan --no-verify-jwt
